# PostHog API Configuration
AGENT_POSTHOG_API_KEY=phc_your_personal_api_key_here
AGENT_POSTHOG_HOST=https://app.posthog.com
AGENT_POSTHOG_PROJECT_ID=1

# Agent Behaviour
AGENT_POLL_INTERVAL_SECONDS=30
AGENT_BASELINE_WINDOW_SECONDS=3600
AGENT_SPIKE_THRESHOLD_STD=3.0

# Correlation Thresholds
AGENT_CORRELATION_CONFIDENCE_AUTO_THRESHOLD=0.85
AGENT_CORRELATION_CONFIDENCE_ALERT_THRESHOLD=0.60

# Safety Guardrails
AGENT_MAX_AUTO_ROLLBACKS_PER_HOUR=2
AGENT_COOLDOWN_AFTER_ROLLBACK_SECONDS=300
AGENT_PROTECTED_FLAGS=["billing-v2", "auth-migration"]

# Notification
AGENT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000...

# Simulation (Set to false for real PostHog production connection)
AGENT_USE_SIMULATOR=true
AGENT_SIMULATION_SPEED=1.0 # Acceleration factor for demo/dev
